# Базовый образ с Python 3 и сборкой зависимостей
FROM python:3.12-slim

# Аргументы и переменные
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# Установка зависимостей системы для psycopg2-binary (или psycopg2)
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates netcat-traditional \
    && rm -rf /var/lib/apt/lists/*

# Рабочая директория
WORKDIR /app

# Копируем зависимости и код
# При необходимости: requirements.txt с psycopg2-binary
# Для простоты используем binary пакет
RUN pip install --no-cache-dir psycopg2-binary

# Копируем приложение и конфиг
COPY pinger.py /app/pinger.py
COPY config.json /app/config.json

# Непривилегированный пользователь (опционально)
# RUN useradd -m app && chown -R app:app /app
# USER app

# Команда запуска
CMD ["python", "/app/pinger.py"]
